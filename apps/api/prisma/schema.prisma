// kouji-genka Prisma schema
// REQUIREMENTS.md §7 と CLAUDE.md の規約に準拠
// - 主キー: UUID v7 (Prisma 5.14+ の uuid(7))
// - 監査ログのみ bigserial (件数大・索引効率)
// - タイムスタンプ: timestamptz (UTC 保存・JST 表示は app 側)
// - 命名: テーブル名は複数形 snake_case、enum は Prisma enum

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================================
// Enums
// ===================================================================

/// REQUIREMENTS §10.2 の 5 ロール
enum RoleCode {
  admin // 管理者: 全データ・全機能、ユーザ管理
  planner // 予算編成: 担当工事の予算編集、出来高承認
  field // 現場: 担当工事の日報・出面入力
  accounting // 経理: 全工事の支払・入金、帳票出力
  viewer // 閲覧: 担当工事の閲覧のみ
}

/// REQUIREMENTS §4.6 の監査対象
enum AuditAction {
  create
  update
  delete
  login
  login_failed
  logout
  export
  permission_change
  access_denied
}

/// REQUIREMENTS §3.2 F2.2 / §7.2: 工事ステータス
enum ProjectStatus {
  bidding // 受注前
  in_progress // 施工中
  completed // 完工
  billing // 請求中
  closed // 完了
}

/// REQUIREMENTS §3.2 F2.5 / §7.2: 工事区分 (公共/民間)
enum ProjectType {
  public
  private
}

/// REQUIREMENTS §3.2 F2.5 / §7.2: 構造種別 (土木/建築/改修)
enum ConstructionType {
  civil
  building
  renovation
}

/// REQUIREMENTS §3.13 F12.1: 取引区分
enum CustomerType {
  client // 施主・発注者
  general // 元請
  subcontractor // 外注
  supplier // 仕入
}

/// REQUIREMENTS §4: 実行予算のステータス遷移 (W4)
enum BudgetStatus {
  draft // 作成中
  pending_approval // 承認待ち
  approved // 承認済
  superseded // 旧版 (新バージョンで置換)
}

/// REQUIREMENTS §4: 内訳/代価行の種別 (MARS の明細種別相当)
/// - section:   集計のみのヘッダ (大科目/中分類)。金額は子の合計。
/// - detail:    内訳明細の葉ノード。cost_element 必須。
/// - composite: 代価表ヘッダ。配下の子明細を持ち、自身の単価は子合計を quantity で按分。
enum BudgetItemKind {
  section
  detail
  composite
}

/// REQUIREMENTS §4: 原価要素 (MARS の費目区分相当)
enum CostElement {
  labor // 労務
  material // 材料
  subcontract // 外注
  machine // 機械
  expense // 経費
}

// ===================================================================
// 認証・認可
// ===================================================================

model User {
  id           String    @id @default(uuid(7)) @db.Uuid
  email        String    @unique @db.VarChar(255)
  /// Argon2id によるハッシュ。SSO のみのユーザは null
  passwordHash String?   @map("password_hash") @db.Text
  name         String    @db.VarChar(100)
  roleId       String    @map("role_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  /// TOTP の秘密鍵 (任意有効化)
  mfaSecret    String?   @map("mfa_secret") @db.VarChar(255)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// 論理削除
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  role                 Role                    @relation(fields: [roleId], references: [id])
  projectPermissions   UserProjectPermission[]
  auditLogs            AuditLog[]
  managedProjects      Project[]               @relation("ProjectManager")
  projectStatusChanges ProjectStatusHistory[]  @relation("ProjectStatusChanger")
  submittedBudgets     Budget[]                @relation("BudgetSubmitter")
  approvedBudgets      Budget[]                @relation("BudgetApprover")

  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid(7)) @db.Uuid
  code        RoleCode @unique
  name        String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users User[]

  @@map("roles")
}

/// REQUIREMENTS §3.1 F1.5: ユーザ × 工事 の権限
/// W3 で projects テーブルを追加し、project_id に FK 制約を付与
model UserProjectPermission {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  canView   Boolean  @default(true) @map("can_view")
  canEdit   Boolean  @default(false) @map("can_edit")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("user_project_permissions")
}

// ===================================================================
// 監査ログ (append-only 想定。7 年保持は運用で担保)
// ===================================================================

model AuditLog {
  id         BigInt      @id @default(autoincrement())
  /// 認証失敗時は null (ユーザが特定できないため)
  userId     String?     @map("user_id") @db.Uuid
  occurredAt DateTime    @default(now()) @map("occurred_at") @db.Timestamptz(6)
  action     AuditAction
  entityType String?     @map("entity_type") @db.VarChar(100)
  /// UUID も bigint 由来 ID も入りうるので text
  entityId   String?     @map("entity_id") @db.VarChar(100)
  before     Json?       @db.JsonB
  after      Json?       @db.JsonB
  ipAddress  String?     @map("ip_address") @db.Inet
  userAgent  String?     @map("user_agent") @db.Text

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([occurredAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

// ===================================================================
// 取引先・工事
// ===================================================================

/// REQUIREMENTS §3.13: 取引先マスタ
/// code はユーザ決定により NOT NULL + UNIQUE (他システム連携キー)
model Customer {
  id            String       @id @default(uuid(7)) @db.Uuid
  /// 取引先コード (社内採番、他システム連携キーとして必須)
  code          String       @unique @db.VarChar(50)
  name          String       @db.VarChar(200)
  nameKana      String?      @map("name_kana") @db.VarChar(200)
  customerType  CustomerType @map("customer_type")
  address       String?      @db.Text
  phone         String?      @db.VarChar(50)
  email         String?      @db.VarChar(255)
  contactPerson String?      @map("contact_person") @db.VarChar(100)
  /// 連絡事項・特殊な契約条件などのメモ
  notes         String?      @db.Text
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// 論理削除
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  projects Project[]

  @@index([customerType])
  @@index([deletedAt])
  @@map("customers")
}

/// REQUIREMENTS §3.2 / §7.2: 工事 (project)
/// - contract_amount は numeric(15,0) 円単位、Prisma Client では Decimal、API は文字列で返却
/// - status 変遷は project_status_history に記録
/// - 削除は admin のみ (論理削除)、manager 本人でも不可
model Project {
  id               String           @id @default(uuid(7)) @db.Uuid
  /// 工事番号 (例: 2026-001)、社内採番、UNIQUE
  code             String           @unique @db.VarChar(50)
  /// 件名
  name             String           @db.VarChar(200)
  customerId       String           @map("customer_id") @db.Uuid
  /// 現場所在地
  location         String?          @db.Text
  /// 着工日
  startDate        DateTime?        @map("start_date") @db.Date
  /// 竣工予定日
  endDate          DateTime?        @map("end_date") @db.Date
  /// 実竣工日 (closed 移行時に確定する想定)
  actualEndDate    DateTime?        @map("actual_end_date") @db.Date
  /// 請負金額 (円、numeric(15,0))
  contractAmount   Decimal          @default(0) @map("contract_amount") @db.Decimal(15, 0)
  status           ProjectStatus    @default(bidding)
  projectType      ProjectType      @default(private) @map("project_type")
  constructionType ConstructionType @default(building) @map("construction_type")
  /// 担当者 (現場代理人等)
  managerUserId    String?          @map("manager_user_id") @db.Uuid
  /// 備考・連絡事項
  notes            String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// 論理削除
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)

  customer      Customer                @relation(fields: [customerId], references: [id])
  manager       User?                   @relation("ProjectManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  permissions   UserProjectPermission[]
  statusHistory ProjectStatusHistory[]
  budgets       Budget[]

  @@index([customerId])
  @@index([managerUserId])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

/// 工事ステータス変遷 (REQUIREMENTS §7.1 project_status_history)
/// - 後戻り (closed → in_progress 等) を許容 (DB 制約なし、UI 側で警告)
/// - bigserial PK (件数が増えるため)
model ProjectStatusHistory {
  id          BigInt         @id @default(autoincrement())
  projectId   String         @map("project_id") @db.Uuid
  /// 変更前ステータス (新規作成直後は null)
  fromStatus  ProjectStatus? @map("from_status")
  toStatus    ProjectStatus  @map("to_status")
  changedById String         @map("changed_by_id") @db.Uuid
  changedAt   DateTime       @default(now()) @map("changed_at") @db.Timestamptz(6)
  reason      String?        @db.Text

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changedBy User    @relation("ProjectStatusChanger", fields: [changedById], references: [id])

  @@index([projectId])
  @@index([changedAt])
  @@map("project_status_history")
}

// ===================================================================
// 実行予算 (Budget) と明細ツリー (BudgetItem) — W4
// REQUIREMENTS §4 / CLAUDE.md「階層構造」「金額・数量の扱い」準拠
// ===================================================================

/// 実行予算ヘッダ
/// - 1 Project に対し N Budget (version で世代管理)
/// - 「同一 Project 内でアクティブな (draft/pending_approval/approved) Budget は 1 つ」
///   の制約は後続の partial UNIQUE (raw SQL) で必要に応じて追加予定
model Budget {
  id            String       @id @default(uuid(7)) @db.Uuid
  projectId     String       @map("project_id") @db.Uuid
  version       Int          @default(1)
  status        BudgetStatus @default(draft)
  /// 「初期予算」「実行予算 v2」など、UI 表示用 (任意)
  title         String?      @db.VarChar(200)
  /// 子明細 (level=0) の amount 合計。更新は app 層の集計サービス経由
  totalAmount   Decimal      @default(0) @map("total_amount") @db.Decimal(15, 0)
  /// 申請・承認の追跡
  submittedById String?      @map("submitted_by_id") @db.Uuid
  submittedAt   DateTime?    @map("submitted_at") @db.Timestamptz(6)
  approvedById  String?      @map("approved_by_id") @db.Uuid
  approvedAt    DateTime?    @map("approved_at") @db.Timestamptz(6)
  notes         String?      @db.Text
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// 論理削除
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submitter User?        @relation("BudgetSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  approver  User?        @relation("BudgetApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  items     BudgetItem[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("budgets")
}

/// 予算明細行 (内訳表 + 代価表の統一表現)
/// - parent_id 自己参照ツリー、同一階層内の順序は display_order (1000 刻み運用想定)
/// - kind で section/detail/composite を区別。level は走査・表示用の冗長カラム
/// - 数量 (15,4)、単価 (15,0)、金額 (15,0)。金額は葉=quantity*unitPrice、節点=子合計
///   (app 層で再計算)。API レスポンスは精度ロスゼロのため string 化
model BudgetItem {
  id           String         @id @default(uuid(7)) @db.Uuid
  budgetId     String         @map("budget_id") @db.Uuid
  /// 自己参照 FK。トップレベルは null
  parentId     String?        @map("parent_id") @db.Uuid
  /// 階層レベル (0=ルート)。整合性は app/トリガで担保
  level        Int            @default(0)
  /// 同一 parent 内の並び順 (1000, 2000, 3000 ... で間に挿入できるよう運用)
  displayOrder Int            @default(0) @map("display_order")
  kind         BudgetItemKind @default(detail)
  /// 社内採番の内訳コード (任意)
  code         String?        @db.VarChar(50)
  /// 摘要・名称
  name         String         @db.VarChar(200)
  /// 規格・仕様
  spec         String?        @db.Text
  /// 単位 (m3 / kg / 人工 / 式 など)
  unit         String?        @db.VarChar(20)
  /// 原価要素。kind=detail で必須、section/composite では null
  costElement  CostElement?   @map("cost_element")
  /// 数量 (15,4)
  quantity     Decimal        @default(0) @db.Decimal(15, 4)
  /// 単価 (15,0 円)
  unitPrice    Decimal        @default(0) @map("unit_price") @db.Decimal(15, 0)
  /// 金額 (15,0 円)。葉=quantity*unitPrice、節点=子合計
  amount       Decimal        @default(0) @db.Decimal(15, 0)
  notes        String?        @db.Text
  /// 楽観ロック (CLAUDE.md の方針)
  lockVersion  Int            @default(0) @map("lock_version")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// 論理削除
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  budget   Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent   BudgetItem?  @relation("BudgetItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children BudgetItem[] @relation("BudgetItemTree")

  @@index([budgetId, parentId, displayOrder])
  @@index([parentId])
  @@index([budgetId, costElement])
  @@index([deletedAt])
  @@map("budget_items")
}
