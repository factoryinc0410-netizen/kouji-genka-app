# =================================================================
# kouji-genka 環境変数雛形
# 実際の値は .env (gitignore対象) にコピーして上書きしてください
# =================================================================

# ----- Node -----
NODE_ENV=development

# ----- Database (PostgreSQL 16) -----
# Docker Compose で起動する場合のデフォルト
POSTGRES_USER=kgk
POSTGRES_PASSWORD=kgk_dev_password
POSTGRES_DB=kgk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://kgk:kgk_dev_password@localhost:5432/kgk?schema=public

# ----- Redis 7 -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ----- Web (Next.js / Auth.js v5) -----
NEXTAUTH_URL=http://localhost:3000
# `openssl rand -base64 32` で生成して上書きすること
AUTH_SECRET=change-me-with-openssl-rand-base64-32
# Next.js から API への内部呼び出し URL
INTERNAL_API_URL=http://localhost:3001

# ----- 本番運用サブパス用 (リバースプロキシ連携時) -----
# Factoryskills の nginx で `/kgk/` を Next.js (port 3000) に proxy_pass する運用では、
# 内部リンクと静的アセットパスをサブパス配下に揃えるため basePath を有効化する。
# 開発時 (pnpm dev) は未設定で `/` 直下のまま (既存挙動と完全に同一)。
# 詳細: skills/kouji-genka/docs/adr/ADR-001-addon-integration-strategy.md
# NEXT_PUBLIC_BASE_PATH=/kgk
# NEXTAUTH_URL=https://factoryskills.example.com/kgk
# COOKIE_DOMAIN=factoryskills.example.com
# CORS_ORIGINS=https://factoryskills.example.com

# ----- Playwright E2E 用 (ステージング/本番URL での E2E 実行時) -----
# 開発時は未設定で `http://localhost:3000` (既存挙動)。
# ステージング検証時のみ override する。basePath が有効な環境では `/kgk` まで含める。
# E2E_BASE_URL=https://staging.example.com/kgk

# ----- API (NestJS) -----
API_PORT=3001
API_LOG_LEVEL=info
# `openssl rand -hex 32` で生成して上書きすること
COOKIE_SECRET=change-me-with-openssl-rand-hex-32
COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:3000

# ----- 認証 -----
# Argon2id パラメタ (W2 で利用)
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4
# ログイン試行制限
LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCK_WINDOW_SEC=600
